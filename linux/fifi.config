# FiFi OS kernel config fragment
# Apply on top of linux-zen x86_64_defconfig:
#   make x86_64_defconfig
#   scripts/kconfig/merge_config.sh .config ../fifi.config
#
# Target: linux-zen (github.com/zen-kernel/zen-kernel)
# Zen already provides: PREEMPT, HZ_1000, BFQ, desktop-friendly defaults.
# This fragment adds FiFi-specific requirements and removes what we don't need.

# ── Identification ────────────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-fifi"
CONFIG_DEFAULT_HOSTNAME="fifios"

# ── Preemption (zen default is PREEMPT — keep it) ────────────────────────────
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_NONE is not set
# CONFIG_PREEMPT_VOLUNTARY is not set

# ── Timer frequency: 1000 Hz for low scheduling latency ──────────────────────
CONFIG_HZ_1000=y
CONFIG_HZ=1000

# ── CPU scheduler ─────────────────────────────────────────────────────────────
CONFIG_SCHED_AUTOGROUP=y        # throttle background tasks during gaming

# ── Initramfs (Phase 1: we boot from initramfs only) ─────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE=""
CONFIG_RD_GZIP=y
CONFIG_RD_XZ=y

# ── Display: DRM/KMS ──────────────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y    # fallback FB for early console

# QEMU display (Phase 1 testing)
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_VIRTIO_GPU=y

# AMD GPU (for real hardware — AMDGPU covers all GCN+ cards)
CONFIG_DRM_AMDGPU=y
CONFIG_DRM_AMDGPU_SI=y
CONFIG_DRM_AMDGPU_CIK=y
CONFIG_HSA_AMD=y

# Intel integrated (covers iGPU on any Intel CPU)
CONFIG_DRM_I915=y
CONFIG_DRM_I915_GVT=n

# NVIDIA: we use nvidia-open-dkms (out of tree) — disable nouveau
# CONFIG_DRM_NOUVEAU is not set

# Framebuffer fallback (covers EFI GOP framebuffer on unknown hardware)
CONFIG_DRM_SIMPLEDRM=y
CONFIG_FB=y
CONFIG_FB_EFI=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

# ── Input: evdev (required by FiFi compositor) ───────────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y            # /dev/input/event* — compositor reads this
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_JOYSTICK=y         # gamepads
CONFIG_INPUT_JOYDEV=y
CONFIG_INPUT_UINPUT=y           # synthetic input (useful for testing)
CONFIG_HID=y
CONFIG_USB_HID=y
CONFIG_HID_GENERIC=y
CONFIG_HID_LOGITECH=y
CONFIG_HID_MICROSOFT=y
CONFIG_HID_SONY=y               # PS4/PS5 controller
CONFIG_HID_NINTENDO=y           # Switch Pro controller
CONFIG_HID_STEAM=y              # Steam Controller / Steam Deck gamepad

# ── USB ───────────────────────────────────────────────────────────────────────
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

# ── Audio: ALSA (PipeWire sits on top of ALSA) ───────────────────────────────
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_PCI=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_PREALLOC_SIZE=2048
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_HDA_CODEC_ANALOG=y
CONFIG_SND_HDA_CODEC_SIGMATEL=y
CONFIG_SND_HDA_CODEC_VIA=y
CONFIG_SND_HDA_CODEC_HDMI=y     # HDMI/DisplayPort audio
CONFIG_SND_HDA_CODEC_CIRRUS=y
CONFIG_SND_HDA_CODEC_CS8409=y
CONFIG_SND_HDA_GENERIC=y
CONFIG_SND_VIRTIO=y             # QEMU audio

# ── Network ───────────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y

# QEMU + real hardware NICs we care about
CONFIG_VIRTIO_NET=y
CONFIG_R8169=y                  # RTL8125 2.5GbE (user's hardware)
CONFIG_E1000E=y                 # Intel GbE (common on laptops)
CONFIG_IGB=y                    # Intel GbE server
CONFIG_IWLWIFI=y                # Intel WiFi (AX series etc.)
CONFIG_ATH11K=y                 # Qualcomm WiFi (common on AMD laptops)
# RTL8922AE (user's card) is blacklisted on their machine — no antenna

# ── Storage ───────────────────────────────────────────────────────────────────
CONFIG_VIRTIO_BLK=y             # QEMU disk
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y
CONFIG_SATA_AHCI=y
CONFIG_ATA=y

# ── Filesystems ───────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_BTRFS_FS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_INOTIFY_USER=y           # file watching (apps use this)
CONFIG_OVERLAY_FS=y             # useful for live USB root

# ── VirtIO (QEMU paravirt) ────────────────────────────────────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y

# ── Power management ──────────────────────────────────────────────────────────
CONFIG_ACPI=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y   # good default; gaming mode switches to performance
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_AMD_PSTATE=y             # AMD P-state EPP driver (user's CPU)
CONFIG_INTEL_IDLE=y

# ── Strip unused / debug overhead ─────────────────────────────────────────────
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set
# CONFIG_KGDB is not set
# CONFIG_FTRACE is not set
# CONFIG_KPROBES is not set
# CONFIG_PROFILING is not set
# CONFIG_OPROFILE is not set
# CONFIG_PERF_EVENTS is not set   # re-enable if needed for profiling later
# CONFIG_UNUSED_SYMBOLS is not set
