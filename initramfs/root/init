#!/bin/sh
# FiFi OS — PID 1 init

# ── Mount essential virtual filesystems ──────────────────────────────────────
mount -t proc     none /proc
mount -t sysfs    none /sys
mount -t devtmpfs none /dev
mount -t tmpfs    none /tmp
mount -t tmpfs    none /run

mkdir -p /dev/pts /dev/shm
mount -t devpts   none /dev/pts
mount -t tmpfs    none /dev/shm

# ── Kernel messages: quiet after boot ────────────────────────────────────────
echo 3 > /proc/sys/kernel/printk 2>/dev/null || true

# ── Hostname ──────────────────────────────────────────────────────────────────
echo "fifios" > /proc/sys/kernel/hostname 2>/dev/null || true

# ── PATH ──────────────────────────────────────────────────────────────────────
export PATH=/bin:/sbin:/usr/bin:/usr/sbin
export HOME=/root
export TERM=linux
export XDG_RUNTIME_DIR=/tmp
export WAYLAND_DISPLAY=wayland-0

# ── Banner ────────────────────────────────────────────────────────────────────
clear
cat /etc/fifi-banner

# ── Launch FiFi compositor (Phase 2) ─────────────────────────────────────────
if [ -x /bin/fifi-compositor ]; then
    exec /bin/fifi-compositor
fi

# Fallback: shell if compositor not present
if [ -x /bin/ush ]; then
    exec /bin/ush
else
    exec /bin/sh
fi

exec /bin/sh
